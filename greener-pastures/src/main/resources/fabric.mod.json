{
  "schemaVersion": 1,
  "id": "greenerpastures",
  "version": "${version}",
  "name": "Greener Pastures",
  "description": "A Data Science Mod for Cobblemon breeding - pasture & egg automation with deep, local analytics and charts that players and server admins can pull for themselves. Your data, your machine; nothing phones home.",
  "authors": [
    "DonaldGalliano"
  ],
  "contact": {
    "homepage": "https://modrinth.com/mod/greenerpastures",
    "sources": "https://github.com/DonaldGalliano/greener-pastures",
    "donate": "https://ko-fi.com/donaldgallianoiii"
  },
  "license": "MIT",
  "environment": "*",
  "entrypoints": {
    "main": [
      "com.greenerpastures.GreenerPastures"
    ],
    "client": [
      "com.greenerpastures.client.GreenerPasturesClient"
    ]
  },
  "mixins": [
    "greenerpastures.mixins.json",
    {
      "config": "greenerpastures.client.mixins.json",
      "environment": "client"
    }
  ],
  "depends": {
    "fabricloader": ">=0.16.0",
    "minecraft": "~1.21.1",
    "java": ">=21",
    "fabric-api": "*",
    "cobblemon": ">=1.7.3 <1.8.0",
    "owo": ">=0.12.15"
  },
  "suggests": {
    "cobbreeding": "~2.2.0",
    "mcef": ">=2.1.6"
  }
}